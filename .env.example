OPENROUTER_API_KEY=

OPENROUTER_MODEL=google/gemini-2.5-flash



# RAG_API_HOST=127.0.0.1

# RAG_API_PORT=8080

# Guardrails (document-only RAG safety)
# RAG_GUARDRAILS_ENABLED=true
# RAG_RETRIEVAL_MIN_SCORE=0.18
# RAG_RETRIEVAL_MIN_PAGES=1
# RAG_RESPONSE_MIN_CONTEXT_OVERLAP=0.12
# RAG_GUARDRAIL_BLOCK_INJECTION=true
# RAG_GUARDRAIL_BLOCK_JAILBREAK=true
# RAG_GUARDRAIL_LOG_BLOCKS=true
# RAG_GUARDRAIL_LOG_PATH=data/pageindex/guardrails/blocked_queries.jsonl

# Hierarchical summaries (stored at ingestion)
# RAG_SUMMARY_MAX_CHARS=320
# RAG_SUMMARY_MAX_SOURCE_CHARS=12000
# RAG_SUMMARY_SECTION_PAGES=8

# Notes export uses fpdf2 + python-docx (installed by default)

# Knowledge map (hierarchy + related-topic edges)
# RAG_GRAPH_MAX_NODES=150
# RAG_GRAPH_MAX_RELATED_EDGES=200
# RAG_GRAPH_RELATED_MIN_SCORE=0.22

# Timeline extraction (regex, explainable)
# RAG_TIMELINE_MAX_EVENTS=500

# Text-to-speech (Hugging Face Inference API)
# HF_TOKEN=hf_...
# RAG_TTS_MODEL=facebook/mms-tts-eng
# RAG_TTS_MAX_CHARS=2500
# RAG_TTS_PROVIDER=hf-inference

# Speech-to-text (same HF_TOKEN as above)
# RAG_STT_MODEL=openai/whisper-large-v3
# RAG_STT_PROVIDER=hf-inference

# Optional: create first user only when users.json is empty (not shown in UI)

# RAG_BOOTSTRAP_USER=admin

# RAG_BOOTSTRAP_PASSWORD=your-secure-password

# RAG_BOOTSTRAP_EMAIL=admin@yourcompany.com


